# Environment variables
# Copy this file to .env and fill in your values

# Application
APP_NAME=NovelVids
APP_VERSION=0.1.0
DEBUG=true

# Database (PostgreSQL or SQLite)
DB_DRIVER=sqlite
DB_HOST=localhost
DB_PORT=5432
DB_USER=novelvids
DB_PASSWORD=novelvids
DB_NAME=novelvids
DB_SQLITE_PATH=./data/novelvids.db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Storage
STORAGE_BASE_PATH=./data/storage
STORAGE_MAX_FILE_SIZE=104857600

# Billing
BILLING_ENABLED=true
BILLING_COST_PER_IMAGE=0.01
BILLING_COST_PER_AUDIO_SECOND=0.001
BILLING_COST_PER_VIDEO_SECOND=0.005

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM API (for character extraction)
# Supports OpenAI-compatible APIs (OpenAI, DeepSeek, Doubao, Moonshot, etc.)
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini
LLM_TIMEOUT=60

# ARK API (for image generation)
# Supports Volcengine ARK API
ARK_API_KEY=your-ark-api-key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL_NAME=doubao-seed-1-6-251015
ARK_IMAGE_SIZE=2K
ARK_TIMEOUT=60

# ARK Vidu API (for video generation)
VIDU_API_KEY=your-doubao-api-key