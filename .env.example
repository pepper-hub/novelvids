# Environment variables
# Copy this file to .env and fill in your values

# Application
APP_NAME=NovelVids
APP_VERSION=0.1.0
DEBUG=true

# Database (PostgreSQL or SQLite)
DB_DRIVER=sqlite
DB_HOST=localhost
DB_PORT=5432
DB_USER=novelvids
DB_PASSWORD=novelvids
DB_NAME=novelvids
DB_SQLITE_PATH=./data/novelvids.db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ComfyUI
COMFYUI_BASE_URL=http://localhost:8188
COMFYUI_API_KEY=
COMFYUI_TIMEOUT=300
COMFYUI_MAX_RETRIES=3
COMFYUI_USE_CLOUD=false
COMFYUI_CLOUD_BASE_URL=
COMFYUI_CLOUD_API_KEY=

# Storage
STORAGE_BASE_PATH=./data/storage
STORAGE_MAX_FILE_SIZE=104857600

# Billing
BILLING_ENABLED=true
BILLING_COST_PER_IMAGE=0.01
BILLING_COST_PER_AUDIO_SECOND=0.001
BILLING_COST_PER_VIDEO_SECOND=0.005

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
